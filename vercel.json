{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/daily-refresh",
      "schedule": "0 2 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/favicon.ico",
      "dest": "frontend/favicon.ico"
    },
    {
      "src": "/favicon.svg",
      "dest": "frontend/favicon.svg"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/app/(.*)",
      "dest": "frontend/$1"
    },
    {
      "src": "/app",
      "dest": "frontend/index.html"
    },
    {
      "src": "/",
      "status": 307,
      "headers": { "Location": "/app/" }
    }
  ]
}
